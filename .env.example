# ====================================
# Technify Academic AI Assistant (TAIA)
# Environment Configuration
# ====================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to Git!

# Groq API Key (Get free at https://console.groq.com/)
LLM_API_KEY=gsk_your-groq-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1

# LLM Settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# FastAPI Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ERP API Base URL (use mock for development)
ERP_API_BASE_URL=http://localhost:8001/api/v1

# JWT Settings (must match ERP's JWT config)
JWT_SECRET_KEY=your-secret-key-from-erp
JWT_ALGORITHM=HS256

# ChromaDB Settings
CHROMA_PERSIST_DIR=./data/vector_store

# Audit Log
AUDIT_LOG_FILE=./logs/audit.log

# CORS (allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
